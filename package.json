{
  "name": "whispertranscribe-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.mjs",
    "kill:ports": "lsof -ti :8787 | xargs kill -9 2>/dev/null; lsof -ti :5173 | xargs kill -9 2>/dev/null; exit 0",
    "dev:fresh": "npm run kill:ports && npm run dev:all",
    "dev:all": "concurrently -k -n api,vite -c blue,green \"npm run server\" \"npm run dev\""
  },
  "dependencies": {
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "@quasar/extras": "^1.17.0",
    "@quasar/vite-plugin": "^1.11.0",
    "quasar": "^2.19.2",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "agentation": "^3.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sass-embedded": "^1.98.0",
    "vite": "^8.0.3"
  }
}
